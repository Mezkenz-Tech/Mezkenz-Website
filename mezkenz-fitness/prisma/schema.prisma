// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Core app models for Mezkenz Fitness

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workouts Workout[]
  vitals   VitalsMeasurement[]
  mbti     MBTIResult[]
}

model Exercise {
  id                 String   @id @default(cuid())
  name               String   @unique
  category           String?
  bodyPart           String?
  equipment          String?
  defaultRestSeconds Int?
  defaultTempo       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  workoutExercises WorkoutExercise[]
}

model Workout {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  date        DateTime @default(now())
  title       String?
  notes       String?
  durationSec Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  exercises WorkoutExercise[]

  @@index([userId])
}

model WorkoutExercise {
  id         String   @id @default(cuid())
  workout    Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  workoutId  String
  exercise   Exercise @relation(fields: [exerciseId], references: [id])
  exerciseId String
  order      Int
  notes      String?

  sets ExerciseSet[]

  @@index([workoutId])
  @@index([exerciseId])
}

model ExerciseSet {
  id                  String          @id @default(cuid())
  workoutExercise     WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)
  workoutExerciseId   String
  setNumber           Int
  reps                Int?
  weightKg            Float?
  restSeconds         Int?
  rpe                 Float? // 1-10 perceived exertion
  timeUnderTensionSec Int?
  isWarmup            Boolean         @default(false)
  notes               String?

  @@unique([workoutExerciseId, setNumber])
  @@index([workoutExerciseId])
}

model VitalsMeasurement {
  id             String   @id @default(cuid())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  timestamp      DateTime @default(now())
  heartRateBpm   Int?
  systolicMmHg   Int?
  diastolicMmHg  Int?
  spo2Percent    Int?
  bodyWeightKg   Float?
  sleepHours     Float?
  readinessScore Int?
  notes          String?

  @@index([userId])
  @@index([timestamp])
}

model MBTIResult {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  type       String // e.g., INTJ, ESFP
  assessedAt DateTime @default(now())
  source     String?

  @@index([userId])
}
